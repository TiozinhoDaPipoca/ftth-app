# ══════════════════════════════════════════════
# Lampejo - Configurações de Ambiente
# ══════════════════════════════════════════════

# Servidor
PORT=3000
NODE_ENV=development
JWT_SECRET=lampejo_secret_key_mude_isso_em_producao

# CORS — origens permitidas (separar por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lampejo
DB_USER=postgres
DB_PASSWORD="sua_senha_aqui"

# IXC Provedor (preencha com dados da sua empresa)
IXC_API_URL=https://SEU_DOMINIO_IXC/webservice/v1
IXC_API_TOKEN=SEU_TOKEN_AQUI

# Upload de fotos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
